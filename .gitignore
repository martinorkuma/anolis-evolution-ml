# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/
.python-version

# ============================================================
# Testing / linting / type-checking caches
# ============================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/
*.ipynb_meta
profile_default/
ipython_config.py

# ============================================================
# Data — large/raw files should not be in git
# Keep directory structure with .gitkeep files inside each
# ============================================================
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Manifest / small reference tables — uncomment to track them
# !data/raw/manifest.csv
# !data/processed/*.csv

# Common bulk-data formats (catch-all)
*.zip
*.tar
*.tar.gz
*.tgz
*.gz
*.bz2
*.7z
*.h5
*.hdf5
*.parquet
*.feather
*.arrow
*.npz
*.npy

# Bayesian / phylogenetic outputs (from your Anolis pipeline)
*.mcmc
*.mcmc.handle.rds
*.rds
*.RData
*.Rhistory
.Rproj.user/

# Sequence / bio-data formats — uncomment any you don't want tracked
*.fasta
*.fa
*.fastq
*.fq
*.bam
*.sam
*.vcf
*.vcf.gz
*.bcf
*.bed
*.gff
*.gff3
*.nwk
*.nex
*.nexus
*.tree

# ============================================================
# Models & trained artifacts
# ============================================================
models/
*.pkl
*.joblib
*.pt
*.pth
*.ckpt
*.onnx
*.pb

# ============================================================
# Pipeline outputs / results / figures
# ============================================================
results/
runs/
wandb/
mlruns/
lightning_logs/

# ============================================================
# Logs
# ============================================================
*.log
logs/

# ============================================================
# Secrets / environment
# ============================================================
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets.yaml

# ============================================================
# Editors / IDEs
# ============================================================
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*~
.\#*
\#*\#

# ============================================================
# OS junk
# ============================================================
# Windows (you're on WSL — Windows tools may touch the tree)
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS (in case anyone collaborates from a Mac)
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.directory
.Trash-*